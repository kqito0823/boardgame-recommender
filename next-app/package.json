        "ai": "^6.0.116",
        "concurrently": "^9.2.1",
        "next": "16.1.6",
        "pg": "^8.20.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.71.2",
        "react-icons": "^5.6.0",
        "react-markdown": "^10.1.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "dotenv": "^17.3.1",
        "eslint": "^9",
